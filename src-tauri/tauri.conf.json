{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mnemo",
  "version": "0.1.0",
  "identifier": "studio.illegal.mnemo",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Mnemo",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:mnemo.db"]
    },
    "shell": {
      "open": true
    },
    "deep-link": {
      "desktop": {
        "schemes": ["mnemo"]
      }
    }
  }
}
